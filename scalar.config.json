{
  "$schema": "https://cdn.scalar.com/schema/scalar-config-next.json",
  "scalar": "2.0.0",
  "info": {
    "title": "Whisp Developer Documentation",
    "description": "SDKs, guides, and REST API reference for integrating Whisp into your apps."
  },
  "siteConfig": {
    "customDomain": "docs.whispchat.com",
    "theme": "default",
    "logo": "docs/assets/whisp-logo.svg",
    "head": {
      "title": "Whisp Docs",
      "meta": [
        {
          "name": "description",
          "content": "Whisp SDK and API documentation."
        }
      ],
      "links": [
        {
          "rel": "icon",
          "href": "/whisp-logo.svg"
        }
      ],
      "styles": [
        {
          "path": "docs/assets/custom.css"
        }
      ]
    },
    "routing": {
      "redirects": [
        {
          "from": "/sdks",
          "to": "/sdks/overview"
        },
        {
          "from": "/sdks/js",
          "to": "/sdks/js/overview"
        }
      ]
    }
  },
  "publishOnMerge": true,
  "publishPreviews": true,
  "pullRequestComments": true,
  "navigation": {
    "header": [
      {
        "type": "link",
        "title": "Status",
        "to": "https://status.whispchat.com",
        "newTab": true
      },
      {
        "type": "link",
        "title": "GitHub",
        "to": "https://github.com/whispchat-com",
        "newTab": true
      }
    ],
    "routes": {
      "/": {
        "type": "page",
        "title": "Overview",
        "filepath": "docs/index.md"
      },
      "/getting-started": {
        "type": "page",
        "title": "Getting Started",
        "filepath": "docs/getting-started.md"
      },
      "/ai-agents": {
        "type": "page",
        "title": "AI Agent Integration",
        "filepath": "docs/ai-agents.md",
        "icon": "phosphor/regular/robot"
      },
      "/sdks": {
        "type": "group",
        "title": "SDKs",
        "mode": "nested",
        "icon": "phosphor/regular/package",
        "children": {
          "overview": {
            "type": "page",
            "title": "SDK Overview",
            "filepath": "docs/sdks/index.md"
          },
          "js": {
            "type": "group",
            "title": "JavaScript / TypeScript",
            "mode": "flat",
            "children": {
              "overview": {
                "type": "page",
                "title": "Overview",
                "filepath": "docs/sdks/js/index.md"
              },
              "installation": {
                "type": "page",
                "title": "Installation",
                "filepath": "docs/sdks/js/installation.md"
              },
              "quickstart-browser": {
                "type": "page",
                "title": "Quickstart (Browser)",
                "filepath": "docs/sdks/js/quickstart-browser.md"
              },
              "quickstart-node": {
                "type": "page",
                "title": "Quickstart (Node.js)",
                "filepath": "docs/sdks/js/quickstart-node.md"
              },
              "authentication": {
                "type": "page",
                "title": "Authentication",
                "filepath": "docs/sdks/js/authentication.md"
              },
              "chats": {
                "type": "page",
                "title": "Chats",
                "filepath": "docs/sdks/js/chats.md"
              },
              "messages": {
                "type": "page",
                "title": "Messages",
                "filepath": "docs/sdks/js/messages.md"
              },
              "realtime": {
                "type": "page",
                "title": "Realtime",
                "filepath": "docs/sdks/js/realtime.md"
              },
              "realtime-actions": {
                "type": "page",
                "title": "Realtime Actions",
                "filepath": "docs/sdks/js/realtime-actions.md"
              },
              "errors": {
                "type": "page",
                "title": "Errors & Retries",
                "filepath": "docs/sdks/js/errors.md"
              },
              "troubleshooting": {
                "type": "page",
                "title": "Troubleshooting",
                "filepath": "docs/sdks/js/troubleshooting.md"
              }
            }
          }
        }
      },
      "/api": {
        "type": "openapi",
        "title": "REST API Reference",
        "filepath": "docs/api-reference/openapi.json",
        "icon": "phosphor/regular/brackets-angle"
      }
    }
  },
  "assetsDir": "docs/assets"
}